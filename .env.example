# Environment Configuration for Skyview Homes

# FOR LOCAL DEVELOPMENT (uses localStorage)
# Leave this commented out to use browser storage
# REACT_APP_API_URL=

# FOR BACKEND API CONNECTION
# Uncomment and set your API URL to enable backend mode
# REACT_APP_API_URL=http://localhost:3001/api

# Examples:
# REACT_APP_API_URL=http://localhost:3001/api
# REACT_APP_API_URL=https://your-backend-domain.com/api
# REACT_APP_API_URL=https://api.skyviewhomes.com/api

# How to use:
# 1. Copy this file to .env
# 2. Uncomment the REACT_APP_API_URL line
# 3. Set your API URL
# 4. Restart development server
